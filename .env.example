# College Scorecard API key — get a free one at https://api.data.gov/signup/
# Used only by the ingest script (scripts/ingest-scorecard.mjs), never shipped to the client.
SCORECARD_API_KEY=your_key_here

# Supabase (optional) — enables accounts + cloud sync. Without these the app runs
# local-first (state in the browser). The anon key is public-safe (protected by RLS).
# Find both under Supabase → Project Settings → API. Add the same two to Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
